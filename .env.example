# ===========================================
# RAG 知识库问答系统配置模板
# ===========================================
# 复制此文件为 .env 并填入您的配置值
# cp .env.example .env

# ===========================================
# API 密钥配置（必填）
# ===========================================
# DashScope API Key（用于通义千问 LLM 和 Embedding）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# ===========================================
# LLM 配置
# ===========================================
# LLM 类型: dashscope (API), ollama (本地), local (本地 Transformers)
LLM_TYPE=dashscope

# LLM 模型名称
# - DashScope: qwen-plus, qwen-turbo, qwen-max
# - Ollama: qwen2.5:7b, llama3:8b, mistral:7b
LLM_MODEL=qwen-plus

# LLM API 基础 URL（仅 DashScope 需要）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===========================================
# Embedding 配置
# ===========================================
# Embedding 类型: dashscope (API), local (本地模型)
EMBEDDING_TYPE=dashscope

# Embedding 模型名称
# - DashScope: text-embedding-v2
# - Local: all-MiniLM-L6-v2, bge-small-zh-v1.5
EMBEDDING_MODEL=text-embedding-v2

# 本地 Embedding 模型（仅 EMBEDDING_TYPE=local 时使用）
EMBEDDING_LOCAL_MODEL=all-MiniLM-L6-v2

# ===========================================
# 重排序（Rerank）配置
# ===========================================
# 重排序方法:
# - none: 不使用重排序
# - vector: 向量相似度重排序（免费，快速）
# - keyword: 关键词匹配重排序（免费，快速）
# - llm: LLM 语义重排序（费用高，效果好）
# - bge: BGE-Reranker-v2-m3 本地重排序（免费，效果好，性能占用低）
RERANK_METHOD=bge

# Reranker 类型: api (DashScope API), local (本地模型)
RERANKER_TYPE=local

# BGE-Reranker 模型名称（仅 RERANK_METHOD=bge 时使用）
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ===========================================
# 向量数据库配置
# ===========================================
# 向量数据库类型: faiss (高性能), memory (纯 Python), auto (自动选择)
VECTOR_DB_TYPE=auto

# ===========================================
# BM25 + 向量混合检索配置
# ===========================================
# BM25 参数（仅在使用混合检索时生效）
BM25_K1=1.5
BM25_B=0.75

# RRF 融合参数
RRF_K=60
RRF_CANDIDATE_FACTOR=3

# ===========================================
# 完全本地运行配置示例
# ===========================================
# 如果想完全本地运行，使用以下配置：
# LLM_TYPE=ollama
# LLM_MODEL=qwen2.5:7b
# EMBEDDING_TYPE=local
# EMBEDDING_LOCAL_MODEL=all-MiniLM-L6-v2
# RERANK_METHOD=bge
# RERANKER_TYPE=local
# VECTOR_DB_TYPE=faiss
